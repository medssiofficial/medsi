{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"globalEnv": [
		"DIRECT_DATABASE_URL",
		"DATABASE_URL",
		"ENV",
		"NEXT_PUBLIC_ADMIN_CLERK_PUBLISHABLE_KEY",
		"CLERK_SECRET_KEY",
		"HOST",
		"TRIGGER_SECRET_KEY",
		"TRIGGER_API_URL",
		"TRIGGER_PROJECT_REF",
		"GOOGLE_GENERATIVE_AI_API_KEY",
		"GOOGLE_GENAI_CASE_ANALYSIS_MODEL",
		"GOOGLE_GENAI_EMBEDDING_MODEL",
		"VERCEL_ENV",
		"NEXT_RUNTIME"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:deploy": {
			"cache": false
		},
		"db:push": {
			"cache": false
		},
		"db:push-dev": {
			"cache": false
		},
		"db:studio": {
			"cache": false
		},
		"db:sync": {
			"cache": false
		}
	}
}
