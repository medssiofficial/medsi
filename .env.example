ENV="development" # Runtime environment: development | production

DATABASE_URL="" # Database URL to connect to Supabase
DIRECT_DATABASE_URL="" # Direct Database URL to connect to Supabase

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="" # Clerk publishable key used by admin and doctor apps
CLERK_SECRET_KEY="" # Clerk secret key used by admin and doctor apps

HOST="" # App host/domain used in Clerk middleware config

DOCTOR_CLERK_SIGNING_SECRET="" # Clerk webhook signing secret for doctor webhook handler
ADMIN_CLERK_SIGNING_SECRET="" # Optional Clerk webhook signing secret for admin webhook handler

RESEND_API_KEY="" # Resend API key for transactional emails
EMAIL_FROM="" # Sender email address, e.g. no-reply@medssi.ankn.dev
EMAIL_REPLY_TO="" # Optional reply-to email address
APP_BASE_URL="" # Public app base URL used for email links