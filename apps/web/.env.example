# Web App (.env)
# Fill in the values below. Clerk keys are available at https://dashboard.clerk.com

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Host used by Clerk middleware for domain binding
HOST="http://localhost:3001"

# Clerk auth routes (required for custom OAuth flows)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/auth/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/auth/sign-up"

# Sentry - Runtime DSN (fill in from your Sentry project settings)
NEXT_PUBLIC_SENTRY_DSN=""

# Sentry only runs in production (and on Vercel, only when VERCEL_ENV=production).
# Set to false to disable Sentry everywhere (emergency kill switch).
# NEXT_PUBLIC_SENTRY_ENABLED=false

# Sentry - Build-time only (used by withSentryConfig to upload source maps)
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
