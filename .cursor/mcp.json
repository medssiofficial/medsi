{
  "mcpServers": {
    "sentry": {
      "url": "https://mcp.sentry.dev/mcp"
    },
    "shadcn": {
      "args": [
        "shadcn@latest",
        "mcp"
      ],
      "command": "npx"
    },
    "trigger": {
      "args": [
        "trigger.dev@latest",
        "mcp",
        "--dev-only"
      ],
      "command": "npx"
    }
  }
}