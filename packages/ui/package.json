{
	"name": "@repo/ui",
	"version": "0.0.0",
	"sideEffects": [
		"**/*.css"
	],
	"files": [
		"dist",
		"src"
	],
	"exports": {
		"./styles.css": "./dist/index.css",
		"./components/ui/*": [
			"./src/components/ui/*.tsx",
			"./src/components/ui/*.ts"
		],
		"./components/brand/*": "./src/components/brand/*.tsx",
		"./components/shells/*": [
			"./src/components/shells/*.tsx",
			"./src/components/shells/*.ts"
		],
		"./lib/*": "./src/lib/*.ts"
	},
	"license": "MIT",
	"scripts": {
		"build:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css",
		"build:components": "tsc --noEmit",
		"check-types": "tsc --noEmit",
		"dev:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
		"dev:components": "tsc --noEmit --watch",
		"lint": "eslint src --max-warnings 0"
	},
	"peerDependencies": {
		"react": "^19"
	},
	"dependencies": {
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.7.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"vaul": "^1.1.2"
	},
	"devDependencies": {
		"@repo/eslint-config": "*",
		"@repo/tailwind-config": "*",
		"@repo/typescript-config": "*",
		"@tailwindcss/cli": "^4.1.5",
		"@types/react": "^19.1.0",
		"eslint": "^9.39.1",
		"tailwindcss": "^4.1.5",
		"typescript": "5.9.2"
	}
}
