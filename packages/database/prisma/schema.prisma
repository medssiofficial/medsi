generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

enum Gender {
    male
    female
    other
}

enum MedicalCaseConversationStatus {
    in_progress
    completed
    cancelled
}

enum MedicalCaseStage {
    chatting
    processing
    analyzed
    ready_for_matching
}

enum IntakeQuestionResponseType {
    text
    file
}

enum CaseChatMessageRole {
    assistant
    user
}

enum CaseEventType {
    case_created
    question_asked
    answer_received
    file_attached
    off_topic_warning
    chat_completed
    chat_cancelled
    processing_started
    file_processing_complete
    analysis_started
    analysis_completed
    analysis_failed
    embedding_generated
}

enum CaseEmbeddingStatus {
    not_embedded
    pending
    synced
    failed
}

enum FileProcessingStataus {
    pending
    processing
    completed
    failed
    not_supported
}

enum PatientFileProcessingSource {
    patient_upload
    patient_manual
    patient_bulk
    admin_manual
    admin_bulk
}

enum PatientFileProcessingLogOutcome {
    success
    failure
    skipped
}

enum FileType {
    text_report
    image_report
}

enum DoctorApplicationStatus {
    pending
    under_review
    approved
    rejected
}

enum DoctorProofType {
    medical_license
    board_certification
    government_id_front
    government_id_back
    specialization_supporting_document
    experience_supporting_document
}

enum PatientDataSharing {
    limited
    full
}

enum DoctorEmbeddingStatus {
    not_embedded
    pending
    synced
    failed
}

enum DoctorEmbeddingSource {
    approval
    manual
    bulk
}

enum DoctorEmbeddingLogOutcome {
    success
    failure
}

model user {
    id         String   @id @default(ulid())
    clerk_id   String   @unique
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    profile        patient_profile?
    settings       patient_settings?
    mediccal_cases medical_case[]
    files          file[]
}

model admin {
    id         String   @id @default(ulid())
    clerk_id   String   @unique
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
}

model doctor {
    id         String   @id @default(ulid())
    clerk_id   String   @unique
    verified   Boolean  @default(false)
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    specializations doctor_specialization[]
    experiences     doctor_experience[]
    profile         doctor_profile?
    expertises      doctor_expertise[]
    application     doctor_application?
    files           doctor_file[]
    embedding_state doctor_embedding_state?
    embedding_logs  doctor_embedding_log[]
}

model doctor_application {
    id               String                  @id @default(ulid())
    doctor_id        String                  @unique
    application_code String?                 @unique
    status           DoctorApplicationStatus @default(pending)
    rejection_reason String?
    submitted_at     DateTime?
    created_at       DateTime                @default(now())
    updated_at       DateTime                @updatedAt

    doctor doctor @relation(fields: [doctor_id], references: [id])
}

model doctor_profile {
    id                          String   @id @default(ulid())
    doctor_id                   String   @unique
    years_of_experience         Decimal
    name                        String
    dob                         DateTime
    gender                      Gender
    email                       String
    mobile_number               String
    country                     String
    address_line_1              String?
    city                        String?
    county                      String?
    medical_registration_number String?
    current_institution         String?
    years_in_practice           Int?
    type_of_doctor              String?
    website_url                 String?
    linkedin_url                String?
    profile_statement           String?
    medical_license_file_id     String?
    board_certification_file_id String?
    government_id_front_file_id String?
    government_id_back_file_id  String?
    experience_proof_file_id    String?
    metadata                    Json?
    created_at                  DateTime @default(now())
    updated_at                  DateTime @updatedAt

    doctor                     doctor      @relation(fields: [doctor_id], references: [id])
    medical_license_file       doctor_file? @relation("doctor_profile_medical_license_file", fields: [medical_license_file_id], references: [id])
    board_certification_file   doctor_file? @relation("doctor_profile_board_certification_file", fields: [board_certification_file_id], references: [id])
    government_id_front_file   doctor_file? @relation("doctor_profile_government_id_front_file", fields: [government_id_front_file_id], references: [id])
    government_id_back_file    doctor_file? @relation("doctor_profile_government_id_back_file", fields: [government_id_back_file_id], references: [id])
    experience_proof_file      doctor_file? @relation("doctor_profile_experience_proof_file", fields: [experience_proof_file_id], references: [id])
}

model doctor_expertise {
    id         String   @id @default(ulid())
    expertise  String
    doctor_id  String
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    doctor doctor @relation(fields: [doctor_id], references: [id])
}

model doctor_specialization {
    id                   String   @id @default(ulid())
    name                 String
    certificate_file_key String
    certificate_file_id  String?
    doctor_id            String?
    created_at           DateTime @default(now())
    updated_at           DateTime @updatedAt

    doctor           doctor?      @relation(fields: [doctor_id], references: [id])
    certificate_file doctor_file? @relation(fields: [certificate_file_id], references: [id])
}

model doctor_experience {
    id                         String   @id @default(ulid())
    start_date                 DateTime
    end_date                   DateTime
    hospital_name              String
    description                String
    experience_letter_file_key String?
    experience_letter_file_id  String?
    doctor_id                  String?
    doctor_application_id      String?
    created_at                 DateTime @default(now())
    updated_at                 DateTime @updatedAt

    doctor                 doctor?      @relation(fields: [doctor_id], references: [id])
    experience_letter_file doctor_file? @relation(fields: [experience_letter_file_id], references: [id])
}

model doctor_file {
    id            String         @id @default(ulid())
    doctor_id     String
    proof_type    DoctorProofType
    filename      String
    mime_type     String
    bucket        String
    storage_path  String
    public_url    String
    size_bytes    Int?
    metadata      Json?
    created_at    DateTime       @default(now())
    updated_at    DateTime       @updatedAt

    doctor                             doctor                 @relation(fields: [doctor_id], references: [id])
    profile_medical_license_for        doctor_profile[]       @relation("doctor_profile_medical_license_file")
    profile_board_certification_for    doctor_profile[]       @relation("doctor_profile_board_certification_file")
    profile_government_id_front_for    doctor_profile[]       @relation("doctor_profile_government_id_front_file")
    profile_government_id_back_for     doctor_profile[]       @relation("doctor_profile_government_id_back_file")
    profile_experience_proof_for       doctor_profile[]       @relation("doctor_profile_experience_proof_file")
    specialization_certificate_for     doctor_specialization[]
    experience_letter_for              doctor_experience[]

    @@index([doctor_id, proof_type])
}

model intake_question {
    id            String                      @id @default(ulid())
    question_text String
    response_type IntakeQuestionResponseType
    order         Int
    is_active     Boolean                     @default(true)
    created_at    DateTime                    @default(now())
    updated_at    DateTime                    @updatedAt

    chat_messages case_chat_message[]
    info_states   case_info_state[]

    @@index([order])
}

model medical_case {
    id                  String                        @id @default(ulid())
    user_id             String
    conversation_status MedicalCaseConversationStatus @default(in_progress)
    case_stage          MedicalCaseStage              @default(chatting)
    language            String                        @default("English")
    off_topic_count     Int                           @default(0)

    collected_data Json?
    summary        String?

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    user            user                @relation(fields: [user_id], references: [id])
    files           case_file[]
    info_state      case_info_state?
    chat_messages   case_chat_message[]
    analysis        case_analysis?
    event_logs      case_event_log[]
    embedding_state case_embedding_state?
}

model patient_profile {
    id         String   @id @default(ulid())
    user_id    String   @unique
    name       String
    age        Int
    gender     Gender
    email      String
    phone      String
    country    String
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    user user @relation(fields: [user_id], references: [id])
}

model patient_settings {
    id                     String             @id @default(ulid())
    user_id                String             @unique
    notifications_enabled  Boolean            @default(true)
    language               String             @default("English")
    data_sharing           PatientDataSharing @default(limited)
    created_at             DateTime           @default(now())
    updated_at             DateTime           @updatedAt

    user user @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model file {
    id                String                @id @default(ulid())
    filename          String
    mime_type         String
    report_type       FileType
    storage_key       String
    processing_status FileProcessingStataus @default(pending)
    metadata          Json?
    processed_data    Json?
    user_id           String
    created_at        DateTime              @default(now())
    updated_at        DateTime              @updatedAt

    user            user                         @relation(fields: [user_id], references: [id])
    case_references case_file[]
    processing_logs patient_file_processing_log[]
    chat_messages   case_chat_message[]
}

model patient_file_processing_log {
    id              String                         @id @default(ulid())
    file_id         String
    source          PatientFileProcessingSource
    outcome         PatientFileProcessingLogOutcome
    error_message   String?
    gemini_model    String?
    trigger_run_id  String?
    metadata        Json?
    created_at      DateTime                       @default(now())

    file file @relation(fields: [file_id], references: [id], onDelete: Cascade)

    @@index([file_id, created_at(sort: Desc)])
    @@index([created_at(sort: Desc)])
}

model case_file {
    id              String   @id @default(ulid())
    medical_case_id String
    file_id         String
    created_at      DateTime @default(now())
    updated_at      DateTime @updatedAt

    medical_case medical_case @relation(fields: [medical_case_id], references: [id])
    file         file         @relation(fields: [file_id], references: [id])
}

model case_chat_message {
    id          String               @id @default(ulid())
    case_id     String
    role        CaseChatMessageRole
    content     String
    file_id     String?
    question_id String?
    metadata    Json?
    created_at  DateTime             @default(now())

    medical_case medical_case      @relation(fields: [case_id], references: [id], onDelete: Cascade)
    file         file?              @relation(fields: [file_id], references: [id])
    question     intake_question?   @relation(fields: [question_id], references: [id])

    @@index([case_id, created_at])
}

model case_analysis {
    id                   String  @id @default(ulid())
    case_id              String  @unique
    detected_specialty   String?
    urgency_level        String?
    ai_confidence        Decimal?
    key_symptoms         Json?
    ai_summary           String?
    collected_information Json?
    gemini_model         String?
    trigger_run_id       String?
    metadata             Json?
    created_at           DateTime @default(now())
    updated_at           DateTime @updatedAt

    medical_case medical_case @relation(fields: [case_id], references: [id], onDelete: Cascade)
}

model case_event_log {
    id         String        @id @default(ulid())
    case_id    String
    event_type CaseEventType
    metadata   Json?
    created_at DateTime      @default(now())

    medical_case medical_case @relation(fields: [case_id], references: [id], onDelete: Cascade)

    @@index([case_id, created_at(sort: Desc)])
    @@index([created_at(sort: Desc)])
}

model case_embedding_state {
    case_id             String              @id
    status              CaseEmbeddingStatus @default(not_embedded)
    last_model          String?
    last_dimensions     Int?
    last_success_at     DateTime?
    last_attempt_at     DateTime?
    last_error          String?
    last_trigger_run_id String?

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    medical_case medical_case @relation(fields: [case_id], references: [id], onDelete: Cascade)
}

model case_info_state {
    id                     String   @id @default(ulid())
    collected_fields       Json     @default("{}")
    current_question_id    String?
    current_question_index Int      @default(0)
    off_topic_streak       Int      @default(0)
    case_id                String   @unique
    created_at             DateTime @default(now())
    updated_at             DateTime @updatedAt

    case     medical_case     @relation(fields: [case_id], references: [id])
    question intake_question? @relation(fields: [current_question_id], references: [id])
}

model doctor_embedding_state {
    doctor_id           String                @id
    status              DoctorEmbeddingStatus @default(not_embedded)
    last_model          String?
    last_dimensions     Int?
    last_success_at     DateTime?
    last_attempt_at     DateTime?
    last_error          String?
    last_trigger_run_id String?

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    doctor doctor @relation(fields: [doctor_id], references: [id], onDelete: Cascade)
}

model doctor_embedding_log {
    id               String                     @id @default(ulid())
    doctor_id        String
    source           DoctorEmbeddingSource
    outcome          DoctorEmbeddingLogOutcome
    error_message    String?
    embedding_model  String?
    dimensions       Int?
    trigger_run_id   String?
    metadata         Json?
    created_at       DateTime                   @default(now())

    doctor doctor @relation(fields: [doctor_id], references: [id], onDelete: Cascade)

    @@index([doctor_id, created_at(sort: Desc)])
    @@index([created_at(sort: Desc)])
}
